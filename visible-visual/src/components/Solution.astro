<section class="section solution-bg">
  <div class="solution-inner">
    <div>
      <span class="section-label">Die Lösung</span>
      <h2 class="section-title">Nährstoffe,<br>die du vergisst<br>zu nehmen.</h2>
      <p class="section-sub" style="margin-bottom:0">Weil sie einfach in deinem Essen sind.</p>
      <div class="solution-steps">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-content">
            <h4>Mikroverkapselung</h4>
            <p>Jedes Nährstoffpartikel wird in eine schützende Hülle eingeschlossen – stabil bis 180°C, geschmacksneutral.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-content">
            <h4>Präzise Dosierung</h4>
            <p>1 Teelöffel BOOST = exakt 100% deines täglichen Nährstoffbedarfs. Kein Rätselraten, kein Überdosieren.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-content">
            <h4>Einfach auf dein Essen</h4>
            <p>Bowl, Pasta, Salat – einfach drüber streuen. Fertig. Keine Verhaltensänderung nötig.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="solution-visual">
      <div style="font-size:13px;font-weight:500;color:var(--mid);margin-bottom:0.5rem;letter-spacing:1px;text-transform:uppercase">Inhaltsstoffe pro Portion</div>
      <div class="nutrient-row">
        <div class="nutrient-icon">🔵</div>
        <div class="nutrient-info">
          <div class="nutrient-name">Vitamin B12</div>
          <div class="nutrient-desc">Nerven & Energie</div>
        </div>
        <div class="nutrient-bar-wrap"><div class="nutrient-bar" style="width:100%"></div></div>
        <div class="nutrient-pct">100%</div>
      </div>
      <div class="nutrient-row">
        <div class="nutrient-icon">☀️</div>
        <div class="nutrient-info">
          <div class="nutrient-name">Vitamin D3</div>
          <div class="nutrient-desc">Immunsystem & Knochen</div>
        </div>
        <div class="nutrient-bar-wrap"><div class="nutrient-bar" style="width:100%"></div></div>
        <div class="nutrient-pct">100%</div>
      </div>
      <div class="nutrient-row">
        <div class="nutrient-icon">🌿</div>
        <div class="nutrient-info">
          <div class="nutrient-name">Omega-3 (Algenöl)</div>
          <div class="nutrient-desc">Herz & Gehirn</div>
        </div>
        <div class="nutrient-bar-wrap"><div class="nutrient-bar" style="width:85%"></div></div>
        <div class="nutrient-pct">85%</div>
      </div>
      <div class="nutrient-row">
        <div class="nutrient-icon">🟡</div>
        <div class="nutrient-info">
          <div class="nutrient-name">Folsäure</div>
          <div class="nutrient-desc">Zellteilung & Wachstum</div>
        </div>
        <div class="nutrient-bar-wrap"><div class="nutrient-bar" style="width:100%"></div></div>
        <div class="nutrient-pct">100%</div>
      </div>
      <div class="nutrient-row">
        <div class="nutrient-icon">⚪</div>
        <div class="nutrient-info">
          <div class="nutrient-name">Selen & Jod</div>
          <div class="nutrient-desc">Schilddrüse & Stoffwechsel</div>
        </div>
        <div class="nutrient-bar-wrap"><div class="nutrient-bar" style="width:100%"></div></div>
        <div class="nutrient-pct">100%</div>
      </div>
      <div style="font-size:11px;color:var(--soft);text-align:center;padding-top:0.5rem">% = Anteil am Tagesbedarf (NRV) pro Portion</div>
    </div>
  </div>
</section>
