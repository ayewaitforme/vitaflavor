<section class="hero">
  <div class="hero-text">
    <div class="hero-badge">Functional Food · Premium</div>
    <h1>Vitamine,<br>die du <em>schmeckst.</em></h1>
    <p class="hero-sub">VITAFLAVOR verwandelt deine tägliche Mahlzeit in eine vollständige Nährstoffversorgung – ohne Tabletten, ohne Aufwand, nur purer Genuss.</p>
    <div class="hero-actions">
      <button class="btn-primary">Starter Kit kaufen – 24,95 €</button>
      <button class="btn-outline">Mehr erfahren</button>
    </div>
    <p class="hero-price-note">Inkl. MwSt. · Kostenloser Versand ab 30 € · 30 Tage Rückgabe</p>
  </div>
  <div class="hero-visual">
    <div class="product-card-mini featured">
      <div class="product-icon icon-gold">🧂</div>
      <div>
        <h3>VITAFLAVOR BOOST</h3>
        <p>Nährstoff-Topping · 150g · Refill</p>
      </div>
      <div class="product-price">
        <div class="price">11,95 €</div>
        <div class="label">Refill</div>
      </div>
    </div>
    <div class="product-card-mini">
      <div class="product-icon icon-green">🫙</div>
      <div>
        <h3>DRIZZLE STARTER KIT</h3>
        <p>Funktionelles Würzöl · 100ml</p>
      </div>
      <div class="product-price">
        <div class="price">24,95 €</div>
        <div class="label">Premium</div>
      </div>
    </div>
    <div class="hero-stat">
      <div class="stat-item">
        <span class="num">0,40€</span>
        <span class="lbl">Pro Tag</span>
      </div>
      <div class="stat-item">
        <span class="num">100%</span>
        <span class="lbl">NRV gedeckt</span>
      </div>
      <div class="stat-item">
        <span class="num">75%</span>
        <span class="lbl">Bruttomarge</span>
      </div>
    </div>
  </div>
</section>
