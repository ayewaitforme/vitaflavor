---
---
<section class="section products-bg">
  <span class="section-label">Unsere Produkte</span>
  <h2 class="section-title">Zwei Produkte.<br>Ein System.</h2>
  <p class="section-sub">Starte mit dem Kit, bleibe mit dem Refill. Oder ergänze mit dem DRIZZLE.</p>
  <div class="products-grid">

    <div class="product-card">
      <div class="product-tag tag-starter">EINSTIEG</div>
      <div class="product-body">
        <span class="product-emoji">🎁</span>
        <div class="product-name">BOOST STARTER KIT</div>
        <div class="product-subtitle">Starter · Master-Box</div>
        <div class="product-desc">Der perfekte Einstieg in die VITAFLAVOR-Welt. Enthält die hochwertige Aufbewahrungsdose, einem hochwertigen Dosierlöffel und deine erste Portion BOOST.</div>
        <ul class="product-features">
          <li>Premium Edelstahl-Aufbewahrungsdose</li>
          <li>Präzisions-Dosierlöffel (1 TL = 1 Portion)</li>
          <li>150g BOOST Erstbefüllung</li>
          <li>Starter-Guide & Rezeptkarte</li>
        </ul>
      </div>
      <div class="product-footer">
        <div>
          <div class="price-big">19,95 €</div>
          <div class="per">Einmalig · inkl. MwSt.</div>
        </div>
        <button class="buy-btn">Kaufen</button>
      </div>
    </div>

    <div class="product-card featured">
      <div class="product-tag tag-bestseller">⭐ BESTSELLER</div>
      <div class="product-body">
        <span class="product-emoji">🧂</span>
        <div class="product-name">VITAFLAVOR BOOST REFILL</div>
        <div class="product-subtitle">Nährstoff-Topping · Refill</div>
        <div class="product-desc">Das Herzstück von VITAFLAVOR. Ein Teelöffel deckt deinen gesamten täglichen Nährstoffbedarf – einfach über deine Bowl oder deinen Salat streuen.</div>
        <ul class="product-features">
          <li>150g / ca. 30 Portionen</li>
          <li>B12, D3, Folsäure, Selen, Jod</li>
          <li>Mikroverkapselt – geschmacksneutral</li>
          <li>100% vegan & natürlich</li>
          <li>Zertifiziert nach EU-Recht</li>
        </ul>
      </div>
      <div class="product-footer">
        <div>
          <div class="price-big">11,95 €</div>
          <div class="per">0,40 € / Tag · 30 Portionen</div>
        </div>
        <button class="buy-btn gold">Kaufen</button>
      </div>
    </div>

    <div class="product-card">
      <div class="product-tag tag-premium">PREMIUM</div>
      <div class="product-body">
        <span class="product-emoji">🫙</span>
        <div class="product-name">DRIZZLE STARTER KIT</div>
        <div class="product-subtitle">Funktionelles Würzöl</div>
        <div class="product-desc">Kalt gepresstes Algenöl mit nativ gebundenem Omega-3 und Vitamin D3. Als Dressing oder Finish-Öl – der eleganteste Weg zur Nährstoffversorgung.</div>
        <ul class="product-features">
          <li>100ml Premium-Algenöl</li>
          <li>Omega-3 & Vitamin D3 nativ gebunden</li>
          <li>Keine Verkapselung nötig</li>
          <li>Mild-nussiger Eigengeschmack</li>
        </ul>
      </div>
      <div class="product-footer">
        <div>
          <div class="price-big">24,95 €</div>
          <div class="per">Premium · Preisanker</div>
        </div>
        <button class="buy-btn">Kaufen</button>
      </div>
    </div>

  </div>
</section>
